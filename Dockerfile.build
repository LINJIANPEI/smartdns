FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 拷贝整个仓库（你 fork 的源码）
WORKDIR /build
COPY . /build

# 编译（关键：静态）
RUN make STATIC=1 -j$(nproc)

# 运行时把二进制拷到挂载目录
CMD ["sh", "-c", "cp /build/src/smartdns /output/ && echo 'build done'"]